        <&cru FCLK_CM0S>,
        <&cru ACLK_CCI>,
        <&cru PCLK_ALIVE>,
        <&cru ACLK_GMAC>,
        <&cru SCLK_CS>,
        <&cru SCLK_CCI_TRACE>,
        <&cru ARMCLKL>,
        <&cru ARMCLKB>,
        <&cru PLL_NPLL>,
        <&cru ACLK_GPU>,
        <&cru PLL_GPLL>,
        <&cru ACLK_PERIHP>,
        <&cru HCLK_PERIHP>,
        <&cru PCLK_PERIHP>,
        <&cru ACLK_PERILP0>,
        <&cru HCLK_PERILP0>,
        <&cru PCLK_PERILP0>,
        <&cru HCLK_PERILP1>,
        <&cru PCLK_PERILP1>,
        <&cru SCLK_I2C1>,
        <&cru SCLK_I2C2>,
        <&cru SCLK_I2C3>,
        <&cru SCLK_I2C5>,
        <&cru SCLK_I2C6>,
        <&cru SCLK_I2C7>,
        <&cru SCLK_SPI0>,
        <&cru SCLK_SPI1>,
        <&cru SCLK_SPI2>,
        <&cru SCLK_SPI4>,
        <&cru SCLK_SPI5>,
        <&cru ACLK_GIC>,
        <&cru ACLK_ISP0>,
        <&cru ACLK_ISP1>,
        <&cru SCLK_VOP0_PWM>,
        <&cru SCLK_VOP1_PWM>,
        <&cru PCLK_EDP>,
        <&cru ACLK_HDCP>,
        <&cru ACLK_VIO>,
        <&cru HCLK_SD>,
        <&cru SCLK_CRYPTO0>,
        <&cru SCLK_CRYPTO1>,
        <&cru SCLK_EMMC>,
        <&cru ACLK_EMMC>,
        <&cru ACLK_CENTER>,
        <&cru ACLK_IEP>,
        <&cru ACLK_RGA>,
        <&cru SCLK_RGA_CORE>,
        <&cru ACLK_VDU>,
        <&cru ACLK_VCODEC>,
        <&cru PCLK_DDR>,
        <&cru ACLK_GMAC>,
        <&cru SCLK_VDU_CA>,
        <&cru SCLK_VDU_CORE>,
        <&cru ACLK_USB3>,
        <&cru FCLK_CM0S>,
        <&cru ACLK_CCI>,
        <&cru PCLK_ALIVE>,
        <&cru SCLK_CS>,
        <&cru SCLK_CCI_TRACE>,
        <&cru ACLK_VOP0>,
        <&cru HCLK_VOP0>,
        <&cru ACLK_VOP1>,
        <&cru HCLK_VOP1>;
	assigned-clock-rates = <75000000>, <50000000>,
        <50000000>, <50000000>,
        <50000000>, <100000000>,
        <50000000>, <150000000>,
        <150000000>, <150000000>,
        <50000000>, <150000000>,
        <50000000>, <100000000>,
        <75000000>, <75000000>,
        <816000000>, <816000000>,
        <600000000>, <200000000>,
        <800000000>, <150000000>,
        <75000000>, <37500000>,
        <300000000>, <100000000>,
        <50000000>, <100000000>,
        <50000000>, <100000000>,
        <100000000>, <100000000>,
        <100000000>, <100000000>,
        <100000000>, <50000000>,
        <50000000>, <50000000>,
        <50000000>, <50000000>,
        <200000000>, <400000000>,
        <400000000>, <100000000>,
        <100000000>, <100000000>,
        <400000000>, <400000000>,
        <200000000>, <100000000>,
        <200000000>, <200000000>,
        <100000000>, <400000000>,
        <400000000>, <400000000>,
        <400000000>, <300000000>,
        <400000000>, <200000000>,
        <400000000>, <300000000>,
        <300000000>, <300000000>,
        <300000000>, <300000000>,
        <100000000>, <150000000>,
        <150000000>, <400000000>,
        <100000000>, <400000000>,
        <100000000>;
};

&grf {
    pvtm {
		compatible = "rockchip,rk3399-pvtm";
		clocks = <&cru SCLK_PVTM_CORE_L>, <&cru SCLK_PVTM_CORE_B>, <&cru SCLK_PVTM_GPU>, <&cru SCLK_PVTM_DDR>;
		clock-names = "core_l", "core_b", "gpu", "ddr";
		resets = <&cru SRST_PVTM_CORE_L>, <&cru SRST_PVTM_CORE_B>, <&cru SRST_PVTM_GPU>, <&cru SRST_PVTM_DDR>;
		reset-names = "core_l", "core_b", "gpu", "ddr";
		status = "okay";
	};
};

&io_domains {
    bt656-supply = <&vcc_1v8>;
    audio-supply = <&vcca1v8_codec>;
    sdmmc-supply = <&vccio_sd>;
    gpio1830-supply = <&vcc_3v0>;
    status = "okay";
};

&u2phy0 {
    status = "okay";

    u2phy0_host: host-port {
        status = "okay";
    };

    u2phy0_otg: otg-port {
        vbus-supply = <&vbus_typec_regulator>;
        status = "okay";
    };
};

&u2phy1 {

    status = "okay";

    u2phy1_host: host-port {
        status = "okay";
    };

    u2phy1_otg: otg-port {
        status = "okay";
    };
};
&emmc_phy {
    status = "okay";
};

&mipi_dphy_rx0 {
    status = "okay";

    ports {
        #address-cells = <0x01>;
        #size-cells = <0x00>;

        port@0 {
            reg = <0x00>;
            #address-cells = <0x01>;
            #size-cells = <0x00>;

            mipi_in_ucam0: endpoint@1 {
                reg = <0x01>;
                remote-endpoint = <&ucam_out0>;
                data-lanes = <1 2>;
            };
        };

        port@1 {
            reg = <0x01>;
            #address-cells = <0x01>;
            #size-cells = <0x00>;

            dphy_rx0_out: endpoint@0 {
                reg = <0x00>;
                remote-endpoint = <&isp0_mipi_in>;
            };
        };
    };
};

&tcphy0 {
	#phy-cells = <0x01>;
	rockchip,typec-conn-dir = <0xe580 0 16>;
	rockchip,usb3tousb2-en = <0xe580 3 19>;
	rockchip,usb3-host-disable = <0x2434 0 16>;
	rockchip,usb3-host-port = <0x2434 12 28>;
	rockchip,external-psm = <0xe588 14 30>;
	rockchip,pipe-status = <0xe5c0 0 0>;
	rockchip,uphy-dp-sel = <0x6268 19 19>;
	status = "okay";
};

&tcphy1 {
	#phy-cells = <0x01>;
	rockchip,typec-conn-dir = <0xe58c 0 16>;
	rockchip,usb3tousb2-en = <0xe58c 3 19>;
	rockchip,usb3-host-disable = <0x2444 0 16>;
	rockchip,usb3-host-port = <0x2444 12 28>;
	rockchip,external-psm = <0xe594 14 30>;
	rockchip,pipe-status = <0xe5c0 16 16>;
	rockchip,uphy-dp-sel = <0x6268 3 19>;
	status = "okay";
};

&spdif {
	i2c-scl-rising-time-ns = <450>;
	i2c-scl-falling-time-ns = <15>;
	assigned-clocks = <&cru SRST_CM0S_NOC>;
	assigned-clock-parents = <&cru PLL_GPLL>;
	status = "disabled";
};

&i2s0 {

	resets = <&cru SRST_I2S0_8CH>, <&cru SRST_H_I2S0_8CH>;
	reset-names = "reset-m", "reset-h";
	pinctrl-names = "default";
	pinctrl-0 = <&i2s0_8ch_bus>;
	power-domains = <&power RK3399_PD_SDIOAUDIO>;
	rockchip,i2s-broken-burst-len;
	rockchip,playback-channels = <8>;
	rockchip,capture-channels = <8>;
	assigned-clocks = <&cru SRST_CRYPTO0_S>;
	assigned-clock-parents = <&cru PLL_GPLL>;
	status = "okay";
};

&i2s1 {
	resets = <&cru SRST_I2S1_8CH>, <&cru SRST_H_I2S1_8CH>;
	reset-names = "reset-m", "reset-h";
	rockchip,i2s-broken-burst-len;
	rockchip,playback-channels = <8>;
	rockchip,capture-channels = <8>;
	assigned-clocks = <&cru SRST_CRYPTO0_M>;
	assigned-clock-parents = <&cru PLL_GPLL>;
	status = "okay";
};

&i2s2 {
	resets = <&cru SRST_I2S2_8CH>, <&cru SRST_H_I2S2_8CH>;
	reset-names = "reset-m", "reset-h";
	assigned-clocks = <&cru SRST_P_DCF>;
	assigned-clock-parents = <&cru PLL_GPLL>;
	status = "okay";
};

&gpu {
	interrupts = <GIC_SPI 19 IRQ_TYPE_LEVEL_HIGH 0>,
		     <GIC_SPI 20 IRQ_TYPE_LEVEL_HIGH 0>,
		     <GIC_SPI 21 IRQ_TYPE_LEVEL_HIGH 0>;
	interrupt-names = "GPU", "JOB", "MMU";
	power-off-delay-ms = <200>;
	operating-points-v2 = <&gpu_opp_table>;
	mali-supply = <&vdd_gpu>;
	status = "okay";

	gpu_power_model: power_model {
		compatible = "arm,mali-simple-power-model";
		static-coefficient = <411000>;
		dynamic-coefficient = <733>;
		ts = <32000 4700 (-80) 2>;
		thermal-zone = "gpu-thermal";
		voltage = <900>;
		frequency = <500>;
		static-power = <300>;
		dynamic-power = <396>;
	};
};

&vopl {
	compatible = "rockchip,rk3399-vop-lit";
	reg = <0x00 0xff8f0000 0x00 0x600>,
        <0x00 0xff8f1c00 0x00 0x200>,
        <0x00 0xff8f2000 0x00 0x400>;
	reg-names = "regs", "cabc_lut", "gamma_lut";
	clocks = <&cru ACLK_VOP1>, <&cru DCLK_VOP1>, <&cru HCLK_VOP1>, <&cru DCLK_VOP1_DIV>;
	clock-names = "aclk_vop", "dclk_vop", "hclk_vop", "dclk_source";
	assigned-clocks = <&cru DCLK_VOP0_DIV>;
	assigned-clock-parents = <&cru PLL_CPLL>;
	status = "okay";
};

&vopl_mmu {
	interrupt-names = "vopl_mmu";
	clock-names = "aclk", "hclk";
	status = "okay";
};

&vopb {
	compatible = "rockchip,rk3399-vop-big";
	reg = <0x00 0xff900000 0x00 0x600>, 
          <0x00 0xff901c00 0x00 0x200>,
          <0x00 0xff902000 0x00 0x1000>;
	reg-names = "regs", "cabc_lut", "gamma_lut";
	clocks = <&cru ACLK_VOP0>, <&cru DCLK_VOP0>, <&cru HCLK_VOP0>, <&cru DCLK_VOP0_DIV>;
	clock-names = "aclk_vop", "dclk_vop", "hclk_vop", "dclk_source";
	assigned-clocks = <&cru DCLK_VOP0_DIV>;
	assigned-clock-parents = <&cru PLL_CPLL>;
	status = "okay";
};

&vopb_mmu {
	interrupt-names = "vopb_mmu";
	clock-names = "aclk", "hclk";
	status = "okay";
};

&isp0_mmu {
	clock-names = "aclk", "hclk";
	rk_iommu,disable_reset_quirk;
	status = "okay";
};

&isp1_mmu {
	clock-names = "aclk", "hclk";
	rk_iommu,disable_reset_quirk;
	status = "disabled";
};

&hdmi {
    pinctrl-names = "default";
	pinctrl-0 = <&hdmi_i2c_xfer>, <&hdmi_cec>;
	clocks = <&cru PCLK_HDMI_CTRL>, <&cru SCLK_HDMI_SFR>, <&cru PLL_VPLL>, <&cru PCLK_VIO_GRF>, <&cru SCLK_HDMI_CEC>;
	clock-names = "iahb", "isfr", "vpll", "grf", "cec";
	#address-cells = <0x01>;
	#size-cells = <0x00>;
	status = "okay";

	ports {

		hdmi_in: port@0 {
			#address-cells = <0x01>;
			#size-cells = <0x00>;

			hdmi_in_vopb: endpoint@0 {
				status = "disabled";
			};

			hdmi_in_vopl: endpoint@1 {
				status = "okay";
			};
		};
	};
};

&mipi_dsi {
	clocks = <&cru SCLK_DPHY_PLL>, <&cru PCLK_MIPI_DSI0>, <&cru SCLK_DPHY_TX0_CFG>;
	clock-names = "ref", "pclk", "phy_cfg";
	status = "disabled";
};

&mipi_dsi1 {
	clocks = <&cru SCLK_DPHY_PLL>, <&cru PCLK_MIPI_DSI1>, <&cru SCLK_DPHY_TX1RX1_CFG>;
	clock-names = "ref", "pclk", "phy_cfg";
	status = "disabled";
};

&edp {
	clocks = <&cru PCLK_EDP>, <&cru PCLK_EDP_CTRL>;
	clock-names = "dp", "pclk";
	status = "disabled";
};

&gpio0 {
    clocks = <&pmucru SRST_P_GPIO0>;
};

&gpio1 {
    clocks = <&pmucru SRST_P_GPIO1>;
};

&i2c3 {

    i2c3_gpio: i2c3_gpio {
        rockchip,pins =
            <4 RK_PC1 1 &pcfg_pull_none>,
            <4 RK_PB2 1 &pcfg_pull_none>;
    };
};

&i2s0 {

    i2s_8ch_mclk: i2s-8ch-mclk {
        rockchip,pins = <4 RK_PA0 1 &pcfg_pull_none>;
    };
};

&sdio0_bus4 {
    rockchip,pins = 
        <4 RK_PA3 1 0xcc>,
        <4 RK_PA4 1 0xcc>,
        <4 RK_PA5 1 0xcc>,
        <4 RK_PA6 1 0xcc>,
        <4 RK_PA7 1 0xcc>;
};

&pinctrl {
    
    pwm3a {
        pwm3a_pin_pull_down: pwm3a-pin-pull-down {
            rockchip,pins =
                <0 RK_PA6 1 &pcfg_pull_down>;
        };
    };
    
    pwm3b {
        pwm3b_pin_pull_down: pwm3b-pin-pull-down {
            rockchip,pins =
                <1 RK_PB6 1 &pcfg_pull_none>;
        };
    };
    
    pcie {
    
        pcie_clkreqn: pci-clkreqn {
            rockchip,pins = <2 RK_PD2 2 &pcfg_pull_none>;
        };
    
        pcie_clkreqnb: pci-clkreqnb {
            rockchip,pins = <4 RK_PD0 1 &pcfg_pull_none>;
        };
    };
    
    emmc {
        emmc_pwr: emmc-pwr {
            rockchip,pins = <0 RK_PA5 1 &pcfg_pull_up>;
        };
    };

    pmic {

        pmic_int_l: pmic-int-l {
            rockchip,pins = <1 RK_PC5 0x00 &pcfg_pull_up>;
        };

        pmic_dvs2: pmic-dvs2 {
            rockchip,pins = <1 RK_PC2 0x00 &pcfg_pull_down>;
        };

        vsel1_gpio: vsel1-gpio {
            rockchip,pins = <1 RK_PC1 0x00 &pcfg_pull_down>;
        };

        vsel2_gpio: vsel2-gpio {
            rockchip,pins = <1 RK_PB6 0x00 &pcfg_pull_down>;
        };
    };

    usb2 {

        otg_vbus_drv: otg-vbus-drv {
            rockchip,pins = <4 RK_PC5 0 &pcfg_pull_none>;
        };
    };

    vcc_sd {

        vcc_sd_h: vcc-sd-h {
            rockchip,pins = <0 RK_PA1 0 &pcfg_pull_up>;
        };
    };

    fusb30x {

        fusb0_int: fusb0-int {
            rockchip,pins = <1 RK_PA2 0 &pcfg_pull_up>;
        };
    };

    sdio-pwrseq {

        wifi_enable_h: wifi-enable-h {
            rockchip,pins = <0 RK_PB2 0 &pcfg_pull_none>;
        };
    };
    
    wireless-bluetooth {

        uart0_gpios: uart0-gpios {
            rockchip,pins = <2 RK_PC3 0 &pcfg_pull_none>;
        };
    };

    isp {

        cif_clkout: cif-clkout {
            rockchip,pins = <2 RK_PB3 3 &pcfg_pull_none>;
        };

        isp_dvp_d0d7: isp-dvp-d0d7 {
            rockchip,pins = 
                <4 RK_PD3 0 &pcfg_pull_none>,
                <2 RK_PB3 3 &pcfg_pull_none>,
                <2 RK_PA0 3 &pcfg_pull_none>,
                <2 RK_PA1 3 &pcfg_pull_none>,
                <2 RK_PA2 3 &pcfg_pull_none>,
                <2 RK_PA3 3 &pcfg_pull_none>,
                <2 RK_PA4 3 &pcfg_pull_none>,
                <2 RK_PA5 3 &pcfg_pull_none>,
                <2 RK_PA6 3 &pcfg_pull_none>,
                <2 RK_PA7 3 &pcfg_pull_none>,
                <2 RK_PB0 3 &pcfg_pull_none>,
                <2 RK_PB1 3 &pcfg_pull_none>,
                <2 RK_PB2 3 &pcfg_pull_none>;
        };

        isp_shutter: isp-shutter {
            rockchip,pins = 
                <1 RK_PA1 1 &pcfg_pull_none>,
                <1 RK_PA0 1 &pcfg_pull_none>;
        };

        isp_flash_trigger: isp-flash-trigger {
            rockchip,pins = <1 RK_PA3 1 &pcfg_pull_none>;
        };

        isp_flash_trigger_as_gpio: isp-flash-trigger-as-gpio {
            rockchip,pins = <0 RK_PC1 0 &pcfg_pull_none>;
        };
    };

    cam_pins {

        cam0_default_pins: cam0-default-pins {
            rockchip,pins = 
                <4 RK_PD3 0 &pcfg_pull_none>,
                <2 RK_PB3 3 &pcfg_pull_none>;
        };

        cam0_sleep_pins: cam0-sleep-pins {
            rockchip,pins = 
                <4 RK_PD3 3 &pcfg_pull_none>,
                <2 RK_PB3 0 &pcfg_pull_none>;
        };
    };

    buttons {

        pwrbtn: pwrbtn {
            rockchip,pins = <0 RK_PA5 0 &pcfg_pull_up>;
        };
    };

    hdmiin {

        hdmiin_gpios: hdmiin-gpios {
            rockchip,pins = 
                <2 RK_PA5 0 &pcfg_output_high>,
                <2 RK_PA6 0 &pcfg_output_high>,
                <2 RK_PA7 0 &pcfg_pull_none>,
                <2 RK_PB0 0 &pcfg_output_high>,
                <2 RK_PB1 0 &pcfg_output_high>,
                <2 RK_PB2 0 &pcfg_output_low>,
                <2 RK_PB4 0 &pcfg_pull_none>;
        };
    };

    xgpio_beep {

        beep_gpio: beep-gpio {
            rockchip,pins = <4 RK_PC6 0 &pcfg_pull_up>;
        };
    };

    xgpio_fan {

        fan_gpio: fan-gpio {
            rockchip,pins = <1 RK_PC2 0 &pcfg_pull_up>;
        };
    };

    leds {

        led1_ctl: led1-ctl {
            rockchip,pins = <1 RK_PC7 0 &pcfg_pull_up>;
        };

        led2_ctl: led2-ctl {
            rockchip,pins = <0 RK_PB4 0 &pcfg_pull_up>;
        };

        led3_ctl: led3-ctl {
            rockchip,pins = <1 RK_PA1 0 &pcfg_pull_up>;
        };

        led4_ctl: led4-ctl {
            rockchip,pins = <0 RK_PB0 0 &pcfg_pull_up>;
        };
    };
};